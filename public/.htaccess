# ====================================================================
# KONFIGURASI .HTACCESS UNTUK SCOPUS SANGIA AI-check
# File: .htaccess (root direktori scopus.sangia.org)
# Tujuan: Mengatur URL routing, keamanan, dan konfigurasi aplikasi
# ====================================================================

# --------------------------------------------------------------------
# BAGIAN 1: KONFIGURASI PHP
# Mengatur parameter PHP untuk performa optimal aplikasi AI
# --------------------------------------------------------------------

# Mengatur maksimal ukuran file yang dapat diupload (50MB)
# Berlaku untuk: Upload dokumen, gambar, dataset, dll
php_value upload_max_filesize 50M

# Mengatur maksimal ukuran total POST data (50MB)  
# Harus >= upload_max_filesize untuk upload berfungsi dengan baik
php_value post_max_size 50M

# Mengatur maksimal waktu eksekusi script (5 menit)
# Diperlukan untuk AI processing yang membutuhkan waktu lebih lama
php_value max_execution_time 300

# Mengatur maksimal waktu input (10 menit)
# Untuk handling request AI yang kompleks
php_value max_input_time 600

# Mengatur maksimal memori (512MB)
# Diperlukan untuk AI model dan processing data besar
php_value memory_limit 512M

# Mengatur timezone server ke Jakarta (WIB)
# Memastikan semua timestamp menggunakan waktu Indonesia
php_value date.timezone 'Asia/Jakarta'

# Mengaktifkan output compression untuk performa
php_flag zlib.output_compression On

# Mengatur session timeout (24 menit)
php_value session.gc_maxlifetime 1440


# --------------------------------------------------------------------
# BAGIAN 2: KEAMANAN DIREKTORI
# Mencegah browsing direktori dan akses tidak sah
# --------------------------------------------------------------------

# Menonaktifkan directory browsing untuk keamanan
# Mencegah pengunjung melihat daftar file dalam direktori
Options All -Indexes

# Menyembunyikan semua file dari directory listing
# Backup keamanan jika Options -Indexes tidak bekerja
IndexIgnore *

# Menyembunyikan informasi server untuk keamanan
ServerSignature Off

# Mencegah akses ke file konfigurasi sensitif
<Files ~ "\.(htaccess|htpasswd|ini|log|sh|sql|conf|config|bak|backup)$">
    Order Allow,Deny
    Deny from all
</Files>

# Mencegah akses ke file temporary dan cache
<Files ~ "\.(tmp|temp|cache|swp|~)$">
    Order Allow,Deny
    Deny from all
</Files>


# --------------------------------------------------------------------
# BAGIAN 3: HEADER KEAMANAN
# Menambahkan security headers untuk proteksi tambahan
# --------------------------------------------------------------------

<IfModule mod_headers.c>
    # Mencegah clickjacking attacks
    Header always append X-Frame-Options SAMEORIGIN
    
    # Mencegah MIME-type sniffing
    Header always set X-Content-Type-Options nosniff
    
    # Mengaktifkan XSS Protection
    Header always set X-XSS-Protection "1; mode=block"
    
    # Referrer Policy untuk privacy
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    
    # Content Security Policy (disesuaikan untuk CDN resources)
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdnjs.cloudflare.com https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://cdnjs.cloudflare.com https://fonts.googleapis.com; img-src 'self' data: https:; font-src 'self' data: https://cdnjs.cloudflare.com https://fonts.gstatic.com; connect-src 'self' https:;"
</IfModule>


# --------------------------------------------------------------------
# BAGIAN 4: URL REWRITING - KONFIGURASI UTAMA
# Mengatur bagaimana URL diproses dan dialihkan
# --------------------------------------------------------------------

# Mengaktifkan Apache URL Rewrite Engine
RewriteEngine On

# Set base URL untuk rewrite rules
RewriteBase /

# REDIRECT NON-WWW KE WWW (OPSIONAL)
# Tujuan: Standarisasi domain untuk SEO dan konsistensi
# Uncomment jika ingin menggunakan www.scopus.sangia.org
# RewriteCond %{HTTP_HOST} ^scopus\.sangia\.org$ [NC]
# RewriteRule ^(.*)$ https://www.scopus.sangia.org/$1 [R=301,L]

# FORCE HTTPS
# Mengalihkan semua traffic HTTP ke HTTPS untuk keamanan
RewriteCond %{HTTPS} off
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

<IfModule mod_rewrite.c>
 RewriteEngine On
 
 
 # ----------------------------------------------------------------
 # BAGIAN 5: HALAMAN UTAMA - ROOT URL ROUTING
 # Mengatur akses ke halaman utama aplikasi
 # ----------------------------------------------------------------
 
 # ROUTE ROOT URL KE INDEX.PHP (proxy handler)
 # Fungsi: Menampilkan konten melalui PHP proxy (DIAKTIFKAN UNTUK MENCEGAH 404)
 RewriteCond %{REQUEST_URI} ^/?$ [NC]
 RewriteCond %{QUERY_STRING} ^$
 RewriteRule ^$ index.php [L]
 
 
 # ----------------------------------------------------------------
 # BAGIAN 6: API ENDPOINTS - WIZDAM AI SERVICES
 # Mengarahkan URL API ke handler yang sesuai
 # ----------------------------------------------------------------
 
 # API AI CHAT INTERFACE
 # Endpoint: /api/chat
 # Fungsi: Handler untuk AI conversation dan chat interface
 RewriteRule ^api/chat$ api/chat-handler.php [L,QSA]
 
 # API AI DOCUMENT ANALYSIS
 # Endpoint: /api/analyze
 # Fungsi: Handler untuk analisis dokumen dengan AI
 RewriteRule ^api/analyze$ api/document-analyzer.php [L,QSA]
 
 # API AI TEXT GENERATION
 # Endpoint: /api/generate
 # Fungsi: Handler untuk text generation dengan AI
 RewriteRule ^api/generate$ api/text-generator.php [L,QSA]
 
 # API AI SUMMARIZATION
 # Endpoint: /api/summarize  
 # Fungsi: Handler untuk summarization text dengan AI
 RewriteRule ^api/summarize$ api/summarizer.php [L,QSA]
 
 # API AI TRANSLATION
 # Endpoint: /api/translate
 # Fungsi: Handler untuk translation dengan AI
 RewriteRule ^api/translate$ api/translator.php [L,QSA]
 
 # API USER AUTHENTICATION
 # Endpoint: /api/auth
 # Fungsi: Handler untuk user login dan authentication
 RewriteRule ^api/auth$ api/auth-handler.php [L,QSA]
 
 # API FILE UPLOAD
 # Endpoint: /api/upload
 # Fungsi: Handler untuk upload file dan dokumen
 RewriteRule ^api/upload$ api/upload-handler.php [L,QSA]
 
 # API SYSTEM STATUS
 # Endpoint: /api/status
 # Fungsi: Health check dan status monitoring
 RewriteRule ^api/status$ api/status-check.php [L,QSA]
 
 
 # ----------------------------------------------------------------
 # BAGIAN 7: KEAMANAN APLIKASI - PROTEKSI FILE SENSITIF
 # Mencegah akses langsung ke file konfigurasi dan internal
 # ----------------------------------------------------------------
 
 # BLOKIR AKSES DIREKTORI CONFIG
 # Mencegah akses ke: /config/, /includes/, /vendor/, dll
 RewriteRule ^(config|includes|vendor|logs|cache|temp)/?$ error/403.html [L]
 RewriteRule ^(config|includes|vendor|logs|cache|temp)/(.*)$ error/403.html [L]
 
 # BLOKIR AKSES FILE INTERNAL PHP
 # Mencegah akses langsung ke file internal aplikasi
 RewriteCond %{REQUEST_URI} ^/(classes|lib|core)/ [NC]
 RewriteRule ^(.*)$ error/403.html [L]
 
 # BLOKIR AKSES FILE DATABASE
 # Mencegah download file database dan backup
 RewriteCond %{REQUEST_URI} \.(sql|db|sqlite|mdb)$ [NC]
 RewriteRule ^(.*)$ error/403.html [L]
 
 # PROTEKSI ENVIRONMENT FILES
 # Mencegah akses ke file .env, .config, dll
 RewriteCond %{REQUEST_URI} ^\.(env|config) [NC]
 RewriteRule ^(.*)$ error/403.html [L]
 
 
 # ----------------------------------------------------------------
 # BAGIAN 8: RATE LIMITING & DDOS PROTECTION
 # Perlindungan terhadap spam dan serangan DDoS
 # ----------------------------------------------------------------
 
 # BLOKIR USER AGENT SUSPICIOUS
 # Mencegah akses dari bot dan scraper yang mencurigakan
 RewriteCond %{HTTP_USER_AGENT} ^$ [OR]
 RewriteCond %{HTTP_USER_AGENT} (libwww|wget|python|nikto|curl|scan|java|winhttp|clshttp|loader) [NC]
 # Baris di bawah ini DINONAKTIFKAN agar tidak memicu error 403 (False Positive)
 # RewriteCond %{HTTP_USER_AGENT} (;|<|>|'|"|\)|\(|%0A|%0D|%27|%3C|%3E|%00) [NC]
 RewriteRule ^(.*)$ error/403.html [F,L]
 
 # BLOKIR REQUEST METHOD BERBAHAYA
 # Hanya izinkan GET, POST, HEAD, OPTIONS
 RewriteCond %{REQUEST_METHOD} ^(TRACE|DELETE|TRACK|PUT|PATCH) [NC]
 RewriteRule ^(.*)$ error/403.html [F,L]
 
 
 # ----------------------------------------------------------------
 # BAGIAN 9: CACHING & PERFORMANCE
 # Mengoptimalkan performa dengan browser caching
 # ----------------------------------------------------------------
 
 # BROWSER CACHING UNTUK STATIC FILES
 <IfModule mod_expires.c>
     ExpiresActive On
     ExpiresByType text/css "access plus 1 month"
     ExpiresByType application/javascript "access plus 1 month"
     ExpiresByType image/png "access plus 1 year"
     ExpiresByType image/jpg "access plus 1 year"
     ExpiresByType image/jpeg "access plus 1 year"
     ExpiresByType image/gif "access plus 1 year"
     ExpiresByType image/svg+xml "access plus 1 year"
     ExpiresByType application/pdf "access plus 1 month"
     ExpiresByType text/html "access plus 1 day"
 </IfModule>
 
 # GZIP COMPRESSION
 <IfModule mod_deflate.c>
     AddOutputFilterByType DEFLATE text/plain
     AddOutputFilterByType DEFLATE text/html
     AddOutputFilterByType DEFLATE text/xml
     AddOutputFilterByType DEFLATE text/css
     AddOutputFilterByType DEFLATE application/xml
     AddOutputFilterByType DEFLATE application/xhtml+xml
     AddOutputFilterByType DEFLATE application/rss+xml
     AddOutputFilterByType DEFLATE application/javascript
     AddOutputFilterByType DEFLATE application/x-javascript
 </IfModule>
 
 
 # ----------------------------------------------------------------
 # BAGIAN 10: ERROR HANDLING
 # Custom error pages untuk user experience yang baik
 # ----------------------------------------------------------------
 
 # CUSTOM ERROR PAGES
 ErrorDocument 400 /error/400.html
 ErrorDocument 401 /error/401.html
 ErrorDocument 403 /error/403.html
 ErrorDocument 404 /error/404.html
 ErrorDocument 500 /error/500.html
 ErrorDocument 502 /error/502.html
 ErrorDocument 503 /error/503.html
 
 
 # ----------------------------------------------------------------
 # BAGIAN 11: FALLBACK ROUTING
 # Rule terakhir untuk menangani request yang tidak tertangkap
 # ----------------------------------------------------------------
 
 # ROUTE UNTUK STATIC FILES
 # Izinkan akses langsung ke file CSS, JS, gambar, dll
 RewriteCond %{REQUEST_FILENAME} -f
 RewriteCond %{REQUEST_URI} \.(css|js|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot|pdf|txt|xml|json)$ [NC]
 RewriteRule ^(.*)$ - [L]
 
 # ROUTE UNTUK HALAMAN APLIKASI
 # Jika file tidak exist, coba route ke controller
 RewriteCond %{REQUEST_FILENAME} !-f
 RewriteCond %{REQUEST_FILENAME} !-d
 RewriteCond %{REQUEST_URI} !^/api/
 RewriteCond %{REQUEST_URI} !^/error/
 
 # FINAL FALLBACK
 # Jika tidak ada yang cocok, tampilkan 404
 RewriteCond %{REQUEST_FILENAME} !-f
 RewriteCond %{REQUEST_FILENAME} !-d
 RewriteRule ^(.*)$ error/404.html [L]
 
</IfModule>


# --------------------------------------------------------------------
# BAGIAN 12: HANDLER PHP - KONFIGURASI SERVER
# Pengaturan versi PHP yang digunakan
# --------------------------------------------------------------------

<Files 403.shtml>
order allow,deny
allow from all
</Files>

# BEGIN cPanel-generated php ini directives, do not edit
# Manual editing of this file may result in unexpected behavior.
# To make changes to this file, use the cPanel MultiPHP INI Editor (Home >> Software >> MultiPHP INI Editor)
# For more information, read our documentation (https://go.cpanel.net/EA4ModifyINI)
<IfModule php8_module>
   php_value error_log "/home/sangiaor/logs/php.error.log"
   php_flag log_errors On
</IfModule>
<IfModule lsapi_module>
   php_value error_log "/home/sangiaor/logs/php.error.log"
   php_flag log_errors On
</IfModule>
# END cPanel-generated php ini directives, do not edit
